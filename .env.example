# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ap_roadmap
DB_USER=root
DB_PASSWORD=

# ── Storage ───────────────────────────────────────────────────────────────────
# Leave blank to use storage/ folder next to app.py
# On VPS set to an absolute path outside the repo e.g. /var/app/storage
STORAGE_ROOT=

# ── App login ─────────────────────────────────────────────────────────────────
# AUTH_USERNAME: the username shown on the login form
# AUTH_PASSWORD_HASH: bcrypt hash of the password
#   Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'YourPassword', bcrypt.gensalt()).decode())"
# AUTH_COOKIE_KEY: any long random string — used to sign session cookies
#   Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_USERNAME=
AUTH_NAME=
AUTH_PASSWORD_HASH=
AUTH_COOKIE_KEY=
